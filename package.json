{
  "name": "leyline",
  "version": "1.0.0",
  "private": true,
  "description": "Leyline - MTG Everything. Connected",
  "workspaces": [
    "apps/api",
    "apps/landing",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @leyline/api",
    "dev:landing": "npm run dev -w @leyline/landing",
    "dev:mobile": "npm run start -w mobile",
    "mobile:ios": "npm run ios -w mobile",
    "mobile:ios:device": "npm run ios:device -w mobile",
    "dev:mobile-prod": "cp apps/mobile/.env apps/mobile/.env.local.bak && cp apps/mobile/.env.production apps/mobile/.env && npm run start -w mobile; cp apps/mobile/.env.local.bak apps/mobile/.env && rm apps/mobile/.env.local.bak",
    "build:api": "npm run build -w @leyline/api",
    "build:landing": "npm run build -w @leyline/landing",
    "docker:push": "./scripts/push-api-ecr.sh",
    "docker:push:api": "./scripts/push-api-ecr.sh",
    "docker:push:landing": "./scripts/push-landing-ecr.sh",
    "k8s:setup": "./scripts/k8s-setup.sh",
    "k8s:deploy:api": "./scripts/deploy-k8s.sh api",
    "k8s:deploy:landing": "./scripts/deploy-k8s.sh landing",
    "k8s:deploy:all": "./scripts/deploy-k8s.sh all",
    "k8s:rollback:api": "./scripts/deploy-k8s.sh api latest --rollback",
    "k8s:rollback:landing": "./scripts/deploy-k8s.sh landing latest --rollback",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0"
  },
  "dependencies": {
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/websockets": "^10.3.0",
    "expo": "~55.0.0-preview.11",
    "react": "19.2.0",
    "react-native": "0.83.2"
  }
}
